# SportsPress Test Environment Configuration
# Copy to .env and modify as needed.

# Sport preset for SportsPress demo data
# Options: ice-hockey, soccer, basketball, baseball, american-football,
#          rugby-league, rugby-union, volleyball, australian-football,
#          cricket, floorball, football, handball, netball
SPORTSPRESS_SPORT=ice-hockey

# Database credentials (internal MariaDB)
WORDPRESS_DB_HOST=localhost:/run/mysqld/mysqld.sock
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_NAME=wordpress
